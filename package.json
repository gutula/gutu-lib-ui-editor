{
  "name": "gutu-lib-ui-editor",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/ui-editor build",
    "typecheck": "bun run --cwd framework/libraries/ui-editor typecheck",
    "lint": "bun run --cwd framework/libraries/ui-editor lint",
    "test": "bun run --cwd framework/libraries/ui-editor test",
    "test:unit": "bun run --cwd framework/libraries/ui-editor test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
